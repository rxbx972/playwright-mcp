# 테스트 대상 URL
BASE_URL=https://your-test-url.example.com

# 로그인용 테스트 계정 (사용자 A)
TEST_USER_A_ID=your_test_user_id
TEST_USER_A_PASSWORD=your_test_user_password

# 사용자 등록 테스트용 계정 (사용자 B)
# TEST_USER_B_ID는 scripts/generate_unique_id.py 실행 시 자동 갱신됩니다
TEST_USER_B_ID=
TEST_USER_B_PASSWORD=your_test_user_password
TEST_USER_B_NAME=your_test_user_name
TEST_USER_B_INITIAL_PASSWORD=your_initial_password

# --- 아래는 llm 모드(--mode llm)에서만 필요 ---
# 기본 실행(rules)에는 OPENAI_API_KEY 없이 동작합니다.
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4o-mini
